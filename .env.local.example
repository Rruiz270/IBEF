# Shared secret used to protect /api/* routes.
# The middleware checks for this value in the `x-api-key` header or `key` query param.
API_SECRET=change-me-to-a-random-secret

# Same value as API_SECRET — exposed to the browser so SyncManager can attach it to requests.
NEXT_PUBLIC_API_KEY=change-me-to-a-random-secret

# Vercel Postgres connection
POSTGRES_URL=

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@institutoi10.org.br
